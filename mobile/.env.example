# Build-time configuration for the native (Capacitor) builds.
#
# The web app reads these at build time (web/src/lib/brand.ts, web/vite.config.ts,
# web/src/lib/app.ts). The native shell has no dev proxy, so the API URL MUST be
# the production HTTPS endpoint, and the store name follows VITE_BRAND_NAME.
#
# Usage:
#   cp .env.example .env
#   set -a; . ./.env; set +a            # export the vars
#   npm run build:web                   # builds web/dist with these values
#   npx cap sync                        # copies dist/ + config into ios/android

# --- API ---
VITE_API_URL=https://api.declick.digital/api/v1

# --- Branding (white-label). Defaults target the DECLICK DIGITAL deployment. ---
# For a SaaS client build, override these (and CAP_APP_ID) with the client's brand.
VITE_BRAND_NAME=DECLICK DIGITAL
VITE_BRAND_OPERATOR=KOMPETENCES DECLICK
VITE_BRAND_ISSUER=KOMPETENCES AFRICA

# Native app/bundle identifier (reverse-DNS). PERMANENT once published to a store.
CAP_APP_ID=digital.declick.app
