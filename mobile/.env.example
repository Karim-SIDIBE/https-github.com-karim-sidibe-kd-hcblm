# Build-time configuration for the native (Capacitor) builds.
# The web app reads VITE_API_URL at build time (web/src/lib/app.ts). For a
# store build it MUST point at the production API over HTTPS — the native shell
# has no dev proxy and localhost is unreachable from a real device.
#
# Usage:
#   cp .env.example .env
#   VITE_API_URL="$(grep -m1 VITE_API_URL .env | cut -d= -f2-)" npm -w web run build
#   npx cap sync
VITE_API_URL=https://api.declick.digital/api/v1
