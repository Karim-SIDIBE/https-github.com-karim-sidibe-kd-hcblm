{
  "name": "@kd/mobile",
  "private": true,
  "version": "0.1.0",
  "description": "Optional Capacitor (iOS/Android) wrappers around the DECLICK DIGITAL PWA (white-label: VITE_BRAND_NAME). Reserve channel for clients requiring an App Store / Play Store presence — the PWA stays primary.",
  "type": "module",
  "scripts": {
    "build:web": "npm -w web run build",
    "add:ios": "cap add ios",
    "add:android": "cap add android",
    "sync": "cap sync",
    "sync:ios": "cap sync ios",
    "sync:android": "cap sync android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "run:ios": "cap run ios",
    "run:android": "cap run android",
    "doctor": "cap doctor",
    "assets": "capacitor-assets generate --assetPath resources",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/network": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "typescript": "^5.6.3"
  }
}
