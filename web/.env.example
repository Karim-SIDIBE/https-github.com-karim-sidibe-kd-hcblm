# Web (PWA) build-time configuration. Copy to .env.local for dev, or pass these
# as environment variables in CI for production/SaaS builds.
#
# Branding is white-label: the defaults below target the in-house DECLICK DIGITAL
# deployment. A SaaS client build overrides VITE_BRAND_* — no code changes.
# See ../BRANDING.md and deploy/presets/.

# API base (absolute — required for native builds; dev defaults to localhost).
VITE_API_URL=http://localhost:4000/api/v1

# Public platform name (the app's name, PWA manifest + title + header).
VITE_BRAND_NAME=DECLICK DIGITAL
# Short name for the installed PWA icon (home screen). Defaults to the 1st word.
VITE_BRAND_SHORT=DECLICK
# Operating department shown as attribution ("Opéré par …").
VITE_BRAND_OPERATOR=KOMPETENCES DECLICK
# Entity that officially certifies (issuer label on certificates / Open Badges).
VITE_BRAND_ISSUER=KOMPETENCES AFRICA
# Brand theme colour (status bar / PWA theme).
VITE_BRAND_THEME=#F36F21
