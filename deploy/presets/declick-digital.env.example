# ──────────────────────────────────────────────────────────────────────────
# DEPLOYMENT PRESET — "Declick Digital" (the in-house Kompetences Africa build)
# ──────────────────────────────────────────────────────────────────────────
# This is the reference deployment. Operated by the KOMPETENCES DECLICK
# department of KOMPETENCES AFRICA; certificates are issued by Kompetences Africa.
# Use this as-is for the production app, and as the template the SaaS preset
# (saas-client.env.example) is inspired by.

# ===== Web / native build (VITE_* — baked at `npm -w web run build`) =====
VITE_API_URL=https://api.declick.digital/api/v1
VITE_BRAND_NAME=Declick Digital
VITE_BRAND_SHORT=Declick
VITE_BRAND_OPERATOR=Kompetences Declick
VITE_BRAND_ISSUER=Kompetences Africa
VITE_BRAND_THEME=#F36F21
# Native (Capacitor) bundle identifier — permanent once published.
CAP_APP_ID=digital.declick.app

# ===== Server (.env — see deploy/.env.example for the full list) =====
CREDENTIAL_ISSUER_NAME=Kompetences Africa
CREDENTIAL_ISSUER_URL=https://declick.digital
CORS_ORIGINS=https://app.declick.digital,https://declick.digital,capacitor://localhost,https://localhost
