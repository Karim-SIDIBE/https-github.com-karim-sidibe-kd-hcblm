# KD-HCBLM API — production environment (VPS).
# Copy to deploy/.env and fill the secrets. NEVER commit deploy/.env.

# --- Database (used by both the db container and the API) ---
POSTGRES_PASSWORD=change-me-to-a-long-random-secret

# --- JWT signing keys (ES256, PEM, single line with \n escapes) ---
# Generate with:  cd server && npx tsx scripts/keygen.ts   (copy the two lines here)
AUTH_JWT_PRIVATE_KEY_PEM=""
AUTH_JWT_PUBLIC_KEY_PEM=""

# --- Production config ---
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
# Disable the dev x-user-id auth bypass in production.
AUTH_DEV_HEADER=false

# Public URLs (used for credential URLs, OpenAPI servers, OAuth issuer).
PUBLIC_BASE_URL=https://api.declick.digital
AUTH_ISSUER=https://api.declick.digital
AUTH_AUDIENCE=declick-api
CREDENTIAL_ISSUER_NAME=KOMPETENCES AFRICA
CREDENTIAL_ISSUER_URL=https://api.declick.digital

# Front-end origins allowed by CORS (comma-separated). Match where the PWA is served.
# If the optional native apps (mobile/, Capacitor) are deployed, also append their
# origins: capacitor://localhost (iOS) and https://localhost (Android). See mobile/README.md.
CORS_ORIGINS=https://app.declick.digital,https://admin.declick.digital,https://entreprise.declick.digital,https://declick.digital

# If the media files are fronted by a CDN, set its base URL (optional). When set,
# ALL video/audio/caption URLs (playback + offline) point to the CDN instead of
# the authenticated API endpoint. Full rollout (BunnyCDN pull-zone / R2): see
# deploy/CDN.md.  Leave blank at launch — the VPS serves media directly.
# MEDIA_PUBLIC_BASE_URL=https://cdn.declick.digital

# --- Optional integrations (leave blank to use the built-in offline fallbacks) ---
# AI (adaptive nudges, tutor, feedback) — without a key, deterministic fallbacks are used.
ANTHROPIC_API_KEY=
# Notification gateways (SMS / WhatsApp / push / email webhook). Blank = console log.
SMS_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
PUSH_WEBHOOK_URL=
NOTIFY_WEBHOOK_URL=
# Transactional e-mail via SMTP (invitations, verification). When SMTP_URL is set,
# EMAIL is sent over SMTP (priority over the webhook above); else webhook; else
# console. Easiest path for a VPS: your provider's SMTP (LWS, Gmail, Sendgrid…).
SMTP_URL=                                   # e.g. smtp://user:pass@smtp.host:587
MAIL_FROM=                                  # e.g. DECLICK DIGITAL <no-reply@declick.digital>
# Set to true if the SMTP host presents a certificate for a different name
# (e.g. LWS shared mail: cert is *.lwspanel.com but you connect to mail.yourdomain).
# The connection stays TLS-encrypted; only the certificate NAME check is skipped.
SMTP_TLS_INSECURE=false
# Learner app base URL, used to build links inside invitations / verification e-mails.
APP_BASE_URL=https://app.declick.digital
# Brand name shown in transactional messages.
BRAND_NAME=DECLICK DIGITAL
# External xAPI LRS forwarding (blank = store locally only).
LRS_ENDPOINT=
LRS_KEY=
LRS_SECRET=

# --- RGPD data lifecycle (retention / erasure), in days ---
# Grace period before a scheduled account erasure is actually purged (and during
# which an admin can restore it). 0 = purge on the next job run.
RGPD_GRACE_DAYS=30
# Audit-log retention (rows hold IPs): purged beyond this age by the retention job.
AUDIT_RETENTION_DAYS=365
# Spent/expired refresh tokens are kept this long (housekeeping) then purged.
TOKEN_RETENTION_DAYS=30

# --- Encryption at rest (application-level field encryption) ---
# 32-byte base64 key; encrypts sensitive columns (2FA TOTP secret) so a DB-only
# leak does not expose them. Generate once:  openssl rand -base64 32
# Keep it OUT of the database and back it up safely (losing it = unreadable 2FA secrets).
FIELD_ENCRYPTION_KEY=

# --- Upload antivirus ---
# clamd host:port for real malware scanning of uploads (blank = heuristic-only:
# EICAR test signature + executable rejection). With Docker, add a clamav service
# and set CLAMAV_HOST=clamav. AV_FAIL_CLOSED=true blocks uploads if clamd is down.
CLAMAV_HOST=
CLAMAV_PORT=3310
AV_FAIL_CLOSED=false

# --- Backups (deploy/backup.sh) ---
# How many days of local dumps to keep before pruning.
BACKUP_RETENTION_DAYS=14
# Off-site destination (rclone remote) — STRONGLY recommended so a full VPS loss
# is recoverable. Configure rclone first (`rclone config`), then set e.g.:
# BACKUP_RCLONE_REMOTE=r2:declick-backups
BACKUP_RCLONE_REMOTE=
