{
  "name": "kd-hcblm-server",
  "version": "0.1.0",
  "private": true,
  "description": "KD-HCBLM v2.0 — Kompetences Declick learning platform backend",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "keygen": "tsx scripts/keygen.ts",
    "test": "node --test --import tsx --env-file=.env \"src/**/*.test.ts\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@kd/shared": "*",
    "@node-rs/argon2": "^2.0.2",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "fast-xml-parser": "^4.5.6",
    "fastify": "^4.28.1",
    "jose": "^5.10.0",
    "pdfkit": "^0.15.2",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.19.19",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
