// KD-HCBLM v2.0 — Prisma schema
// ---------------------------------------------------------------------------
// Two faces of the platform (see handoff README):
//   A. AUTHORING  — a Course has many versioned CourseVersions. Each version
//      stores the full authored content as a validated JSONB document whose
//      shape is the Zod "content model" (src/domain/content-model.ts). This is
//      the single contract shared by the authoring form, the publish-time
//      validation engine, and the learner renderer.
//   B. RUNTIME    — learners enrol in a published CourseVersion; their progress,
//      badges and submissions are normalized relational rows (fleshed out in a
//      later step; stubbed here so the model is coherent end-to-end).
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

/// Platform roles. Beyond the original handoff set, modern-LMS roles are added:
/// SUPER_ADMIN (platform owner), REVIEWER (content approval gate) and INSTRUCTOR
/// (delivery / cohort management).
enum Role {
  LEARNER
  LEARNING_DESIGNER
  REVIEWER
  INSTRUCTOR
  EVALUATOR
  COURSE_ADMIN
  SUPER_ADMIN
  ENTERPRISE_CLIENT
  EMPLOYER
}

/// Certification levels. Levels differ only by thresholds + content depth.
enum CourseLevel {
  L1
  L2
  L3
}

/// Lifecycle of a single authored version (draft → review → published).
enum CourseStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

/// Enrolment lifecycle.
enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CERTIFIED
  WITHDRAWN
}

/// Progressive block badges (one per block) + the final certificate.
enum BadgeType {
  ENTRY // Bloc 0
  COMPREHENSION // Bloc 1
  PRACTICE // Bloc 2
  ANCHORING // Bloc 3
  CERTIFICATE // Bloc 4
}

/// Discrete completable items inside a course (engine progress tracking).
enum ItemType {
  PROFILE // Bloc 0 — time-management profile chosen
  TRIGGER_QUIZ // Bloc 0 — non-scored trigger quiz
  PEER // Bloc 0 — progress peer designated
  MICRO_SESSION // a video + exercise micro-session
  DIAGNOSTIC_QUIZ // Bloc 1 — scored diagnostic
  CASE_STUDY // Bloc 1 — Nadia
  GUIDED_SCENARIOS // Bloc 2 — guided situations
  INTER_BLOCK_QUIZ // Bloc 2 — non-scored consolidation quiz
  FIELD_APPLICATION // Bloc 2 — field application (gates Bloc 3)
  SELF_ASSESSMENT // Bloc 3 — 6-criteria self assessment
  ACTION_PLAN // Bloc 3 — 30-day plan
  FINAL_QUIZ // Bloc 3 — scored final quiz (gates Bloc 4)
  PROJECT // Bloc 4 — certifying project submission
  JOURNAL_ENTRY // Bloc 4 — one of the 6 micro-entries
  RUBRIC_EVALUATION // Bloc 4 — human evaluator score
}

// ===========================================================================
// Identity
// ===========================================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(LEARNER)
  /// Argon2id hash for first-party password auth (null = SSO-only / no password).
  passwordHash String?
  /// Brute-force lockout (OWASP): failed-attempt counter + temporary lock.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authoredCourses  Course[]              @relation("CourseAuthor")
  reviewedVersions CourseVersion[]       @relation("VersionReviewer")
  enrollments      Enrollment[]
  refreshTokens    RefreshToken[]
  orgMemberships   OrganizationMembership[]
  hostedSessions   LiveSession[]         @relation("SessionHost")
  sessionRegistrations SessionRegistration[]
  cohortMemberships CohortMembership[]
  authoredThreads  ForumThread[]         @relation("ThreadAuthor")
  authoredPosts    ForumPost[]           @relation("PostAuthor")
  evaluatorAssignments ProjectSubmission[] @relation("EvaluatorAssignments")

  @@index([role])
}

/// Rotating refresh tokens with reuse detection (OAuth 2.0 Security BCP, RFC 9700).
/// Only the SHA-256 of the opaque token is stored. A whole `familyId` is revoked
/// when a previously-rotated (revoked) token is presented again.
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId     String // rotation family
  tokenHash    String    @unique // sha256(opaque token)
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String? // next token in the rotation chain
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

/// Append-only audit trail for security-sensitive events.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // principal id (null for anonymous / system)
  action     String // e.g. "auth.login.success", "course.publish"
  targetType String?
  targetId   String?
  ip         String?
  meta       Json?
  at         DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([at])
}

// ===========================================================================
// A. Authoring — Course + versioned content document
// ===========================================================================

/// A tenant (organization / workspace). Org-scoped resources are isolated to it;
/// resources with no organization are the shared platform catalog.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  /// SCIM provisioning bearer-token hash (set when SCIM is enabled for the org).
  scimTokenHash String?
  createdAt DateTime @default(now())

  memberships OrganizationMembership[]
  courses     Course[]
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model OrganizationMembership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgRole        OrgRole      @default(MEMBER)
  /// External id when provisioned via SCIM.
  scimExternalId String?
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
}

model Course {
  id        String   @id @default(cuid())
  /// Stable human-readable identifier, e.g. "gestion-du-temps-n1".
  slug      String   @unique
  /// Owning tenant; null = shared platform catalog.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String?
  author   User?   @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  versions     CourseVersion[]
  enrollments  Enrollment[]
  liveSessions LiveSession[]
  cohorts      Cohort[]

  @@index([authorId])
}

/// A cohort — a group of learners, optionally tied to a course. Forums are
/// scoped per cohort ("forum de pratique optionnel par cohorte", Pilier 6.3).
model Cohort {
  id          String   @id @default(cuid())
  name        String
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime @default(now())

  memberships CohortMembership[]
  threads     ForumThread[]

  @@index([courseId])
}

model CohortMembership {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([cohortId, userId])
  @@index([userId])
}

model ForumThread {
  id        String      @id @default(cuid())
  cohortId  String
  cohort    Cohort      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?       @relation("ThreadAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title     String
  locked    Boolean     @default(false)
  pinned    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  posts ForumPost[]

  @@index([cohortId])
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?       @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  editedAt  DateTime?
  deletedAt DateTime? // soft delete for moderation
  createdAt DateTime    @default(now())

  @@index([threadId])
}

/// A registered LTI 1.3 Platform (an LMS that launches into us, the Tool).
model LtiPlatform {
  id           String     @id @default(cuid())
  name         String?
  issuer       String
  clientId     String
  deploymentId String?
  authLoginUrl String // platform OIDC auth endpoint
  jwksUrl      String // platform public keys
  tokenUrl     String? // platform OAuth token endpoint (AGS/NRPS)
  createdById  String?
  createdAt    DateTime   @default(now())
  nonces       LtiNonce[]

  @@unique([issuer, clientId])
}

/// Short-lived state/nonce bridging the LTI OIDC login → launch.
model LtiNonce {
  id            String      @id @default(cuid())
  state         String      @unique
  nonce         String
  platformId    String
  platform      LtiPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  targetLinkUri String?
  createdAt     DateTime    @default(now())
  expiresAt     DateTime
}

/// Imported interoperable content packages (SCORM 1.2 / 2004, cmi5).
enum ImportType {
  SCORM12
  SCORM2004
  CMI5
}

model ImportedPackage {
  id           String              @id @default(cuid())
  type         ImportType
  title        String
  storagePrefix String // object-key prefix where the package files live
  launchHref   String // entry file relative to the prefix
  structure    Json? // parsed manifest structure (items / AUs)
  createdById  String?
  createdAt    DateTime            @default(now())

  registrations ScormRegistration[]
  inbound       InboundStatement[]

  @@index([type])
}

/// Per-learner runtime tracking for an imported package (SCORM data model / cmi5 state).
model ScormRegistration {
  id               String          @id @default(cuid())
  packageId        String
  package          ImportedPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  userId           String
  completion       String? // completed | incomplete | not attempted
  success          String? // passed | failed | unknown
  scoreScaled      Float?
  scoreRaw         Int?
  location         String?
  suspendData      String?
  totalTimeSeconds Int?
  cmi              Json? // raw SCORM cmi tree
  authToken        String? // cmi5 inbound auth token
  updatedAt        DateTime        @updatedAt
  createdAt        DateTime        @default(now())

  @@unique([packageId, userId])
  @@index([userId])
}

/// xAPI statements received from imported cmi5/xAPI content (inbound LRS).
model InboundStatement {
  id        String           @id @default(cuid())
  packageId String?
  package   ImportedPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  userId    String?
  verb      String
  statement Json
  storedAt  DateTime         @default(now())

  @@index([packageId])
}

/// Media pipeline — uploaded assets transcoded into an adaptive rendition ladder
/// (low-bandwidth + offline-downloadable variants).
enum MediaKind {
  VIDEO
  AUDIO
  CAPTIONS
  IMAGE
}

enum MediaStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

model MediaAsset {
  id               String      @id @default(cuid())
  kind             MediaKind   @default(VIDEO)
  originalFilename String?
  mime             String
  sizeBytes        Int?
  durationSec      Int?
  width            Int?
  height           Int?
  status           MediaStatus @default(UPLOADED)
  storageKey       String // source object key
  error            String?
  createdById      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  renditions MediaRendition[]

  @@index([status])
}

model MediaRendition {
  id          String     @id @default(cuid())
  assetId     String
  asset       MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  label       String // "source", "480p", "240p-lite", "audio", "captions-fr"
  kind        MediaKind
  mime        String
  storageKey  String? // local/object key (null when external)
  url         String? // external/provider URL (null when stored)
  bitrateKbps Int?
  width       Int?
  height      Int?
  language    String? // for captions
  sizeBytes   Int?
  downloadable Boolean   @default(false) // suitable for offline download
  available    Boolean   @default(true) // false = planned but not yet transcoded
  createdAt    DateTime   @default(now())

  @@index([assetId])
}

/// Blended / instructor-led live sessions (Zoom, Teams, or a manual link).
enum MeetingProvider {
  ZOOM
  TEAMS
  MANUAL
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveSession {
  id                String          @id @default(cuid())
  /// Optional association with a course (blended learning).
  courseId          String?
  course            Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  title             String
  description       String?
  provider          MeetingProvider @default(MANUAL)
  startsAt          DateTime
  durationMin       Int
  timezone          String          @default("UTC")
  joinUrl           String?
  externalMeetingId String? // the provider's meeting id
  hostUserId        String?
  host              User?           @relation("SessionHost", fields: [hostUserId], references: [id], onDelete: SetNull)
  capacity          Int?
  status            SessionStatus   @default(SCHEDULED)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  registrations SessionRegistration[]

  @@index([courseId])
  @@index([startsAt])
}

model SessionRegistration {
  id                String      @id @default(cuid())
  sessionId         String
  session           LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredAt      DateTime    @default(now())
  attended          Boolean     @default(false)
  attendanceMinutes Int?

  @@unique([sessionId, userId])
  @@index([userId])
}

model CourseVersion {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  /// Monotonic version number within a course (1, 2, 3 …).
  version Int
  status  CourseStatus @default(DRAFT)

  // --- denormalized headline fields (mirrors of content.*, kept for querying) ---
  title         String
  level         CourseLevel
  language      String      @default("fr")
  domainCode    String // e.g. "D4"
  domainLabel   String // e.g. "Productivité & organisation"
  passThreshold Int // Bloc 3 final-quiz threshold: 70 | 75 | 80

  /// The full authored content document — conforms to the Zod content model.
  /// This is the payload the authoring tool produces and the learner UI renders.
  content Json

  // --- review workflow (draft → in_review → published) ---
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?     @relation("VersionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments  Enrollment[]
  searchChunks SearchChunk[]

  @@unique([courseId, version])
  @@index([status])
}

/// Embedded content chunks for semantic search (one set per course version).
/// Vectors stored as JSON float arrays; cosine ranking is computed in-process
/// (swap for pgvector at scale).
model SearchChunk {
  id              String        @id @default(cuid())
  courseVersionId String
  courseVersion   CourseVersion @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  blockIndex      Int?
  path            String // locator, e.g. "blocks[1].diagnostic.q3"
  text            String
  embedding       Json // number[]
  model           String
  createdAt       DateTime      @default(now())

  @@index([courseVersionId])
}

// ===========================================================================
// B. Runtime — learner enrolment + badges (stubs; expanded in a later step)
// ===========================================================================

model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersionId String
  courseVersion   CourseVersion    @relation(fields: [courseVersionId], references: [id])
  status          EnrollmentStatus @default(ACTIVE)

  /// The Moment d'Ancrage (PAM) text — captured once at Bloc 0, then injected
  /// everywhere ({{moment_ancrage}}). Stored at enrolment scope for fast reuse.
  momentAncrage String?

  /// Progress peer (Pilier 6.3) — notified at each badge.
  peerName  String?
  peerEmail String?

  /// Enterprise enrolment → J+14 inactivity signals go to the admin (Pilier 6.4).
  isEnterprise Boolean @default(false)

  // --- auto-resume (Pilier 6.2): exact position the learner last touched ---
  lastBlockIndex Int?
  lastItemKey    String?
  lastSeenAt     DateTime?

  /// Anchor for the journal trigger schedule (Pilier 5.1): set when the
  /// certification block first unlocks ("block start").
  journalStartedAt DateTime?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  badges         Badge[]
  completions    ItemCompletion[]
  reEngagements  ReEngagementMessage[]
  xapi           XapiStatement[]
  notifications  Notification[]
  aiAssessments  AiAssessment[]
  syncOperations SyncOperation[]
  credentials    Credential[]
  tutorSessions  TutorSession[]
  mediaPositions MediaPosition[]
  journalTriggers JournalTrigger[]
  projectSubmission ProjectSubmission?

  @@unique([userId, courseId])
  @@index([status])
}

/// Grounded AI tutor (RAG over the course content). One conversation thread.
model TutorSession {
  id           String         @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  title        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     TutorMessage[]

  @@index([enrollmentId])
}

enum TutorRole {
  USER
  ASSISTANT
}

model TutorMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      TutorRole
  content   String
  /// For assistant turns: the retrieved citations [{blockIndex, path, snippet}].
  citations Json?
  grounded  Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@index([sessionId])
}

/// Idempotency ledger for offline-first sync: one row per applied client action,
/// so replaying a queued action batch never double-applies (Pilier 6.2, offline).
model SyncOperation {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  /// Client-generated operation id (the idempotency key).
  opId         String
  type         String
  clientTs     DateTime
  appliedAt    DateTime   @default(now())

  @@unique([enrollmentId, opId])
  @@index([enrollmentId])
}

/// One per fired journal prompt (Pilier 5.1) — idempotent per (enrolment, day).
model JournalTrigger {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  day          Int // J+1, J+3, J+5, J+7, J+10, J+14
  sentAt       DateTime   @default(now())

  @@unique([enrollmentId, day])
  @@index([enrollmentId])
}

/// Exact in-session position for auto-resume (Pilier 3.2 / 4.2): the video
/// offset (to the nearest 5s) per micro-session, stored server-side so resume
/// works across devices. One row per (enrolment, block, item).
model MediaPosition {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  blockIndex   Int
  itemKey      String
  positionSec  Int        @default(0)
  durationSec  Int?
  updatedAt    DateTime   @updatedAt

  @@unique([enrollmentId, blockIndex, itemKey])
  @@index([enrollmentId])
}

/// Bloc 4 certification project lifecycle (Pilier 6.3) — the authoritative
/// in-platform record for employer / institutional verification: submission,
/// evaluator assignment, per-criterion rubric result, written feedback,
/// pass/fail, revision status, and the 5-business-day SLA alert state.
/// One per enrolment (the final certification deliverable).
model ProjectSubmission {
  id             String         @id @default(cuid())
  enrollmentId   String         @unique
  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  blockIndex     Int
  /// Submission payload: file references or rich-text body.
  submittedAt    DateTime       @default(now())
  content        Json?
  /// Evaluator assignment (an EVALUATOR / staff user).
  evaluatorId    String?
  evaluator      User?          @relation("EvaluatorAssignments", fields: [evaluatorId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?
  /// Evaluation result — mirrors the rubric completion for the verification API.
  scoreTotal     Int?
  criteria       Json?
  feedback       String?
  result         ProjectResult?
  evaluatedAt    DateTime?
  /// SUBMITTED → ASSIGNED → PASSED | REVISION_REQUESTED.
  revisionStatus ProjectStatus  @default(SUBMITTED)
  /// Day+5 SLA: set once the admin alert has fired (idempotent).
  slaAlertedAt   DateTime?

  @@index([evaluatorId])
}

enum ProjectResult {
  PASS
  FAIL
}

enum ProjectStatus {
  SUBMITTED
  ASSIGNED
  PASSED
  REVISION_REQUESTED
}

/// One row per completed content item for an enrolment.
model ItemCompletion {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  blockIndex   Int
  itemType     ItemType
  /// Stable key within the block: micro-session id ("1.1"), "diagnostic",
  /// "final", "J+3", "project", "scenarios", … (singletons use a fixed key).
  itemKey      String
  /// Score for scored items (diagnostic, final quiz, rubric evaluation).
  scorePct     Int?
  /// Raw payload (answers, profile choice, submission text…).
  data         Json?
  completedAt  DateTime   @default(now())

  @@unique([enrollmentId, blockIndex, itemKey])
  @@index([enrollmentId])
}

model Badge {
  id           String      @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  type         BadgeType
  /// Personalized message anchored in the learner's Moment d'Ancrage.
  message      String?
  /// Whether the progress peer has been notified (Pilier 6.3).
  peerNotified Boolean     @default(false)
  issuedAt     DateTime    @default(now())
  credential   Credential?

  @@unique([enrollmentId, type])
}

/// Verifiable credential for an issued badge: Open Badges 2.0 hosted assertion
/// (JSON-LD) + Open Badges 3.0 Verifiable Credential signed as a VC-JWT (ES256,
/// verifiable via the platform JWKS). Recipient identity is salted-hashed.
model Credential {
  id               String     @id @default(cuid())
  badgeId          String     @unique
  badge            Badge      @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  enrollmentId     String
  enrollment       Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  achievementType  String
  recipientSalt    String
  recipientHash    String // sha256(email + salt)
  assertion        Json // OB 2.0 hosted assertion
  vcJwt            String // OB 3.0 VC-JWT
  issuedAt         DateTime   @default(now())
  revokedAt        DateTime?
  revocationReason String?

  @@index([enrollmentId])
}

/// Proactive re-engagement of inactive learners (Pilier 6.4).
enum ReEngagementStage {
  J3 // 3 days inactive
  J7 // 7 days inactive — message anchored in the Moment d'Ancrage
  J14 // 14 days inactive — admin signal for enterprise enrolments
}

enum NotifChannel {
  LEARNER
  ADMIN
}

model ReEngagementMessage {
  id           String            @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  stage        ReEngagementStage
  channel      NotifChannel      @default(LEARNER)
  body         String
  sentAt       DateTime          @default(now())

  @@index([enrollmentId, stage])
}

/// xAPI statements emitted to the LRS (Pilier — analytics / interoperability).
model XapiStatement {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  verb         String // verb IRI
  objectId     String // activity IRI
  statement    Json // the full xAPI statement
  forwarded    Boolean    @default(false)
  forwardedAt  DateTime?
  forwardError String?
  storedAt     DateTime   @default(now())

  @@index([enrollmentId])
  @@index([forwarded])
}

enum NotificationChannel {
  CONSOLE
  EMAIL
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum RecipientKind {
  LEARNER
  PEER
  ADMIN
}

/// AI grading-assistant output (advisory; never auto-applied to certification).
enum AiAssessmentKind {
  FORMATIVE // learner-facing feedback on an open submission
  RUBRIC_SUGGESTION // evaluator-facing per-criterion score suggestion (Bloc 4)
}

model AiAssessment {
  id             String           @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  blockIndex     Int
  itemKey        String
  kind           AiAssessmentKind
  feedback       String // overall text / summary
  /// For RUBRIC_SUGGESTION: [{label, weightPoints, suggested, comment}].
  criteria       Json?
  /// For RUBRIC_SUGGESTION: provisional total /100 (advisory only).
  suggestedScore Int?
  aiGenerated    Boolean          @default(false)
  provider       String?
  createdAt      DateTime         @default(now())

  @@index([enrollmentId])
}

/// Outbound notification (peer congratulations, re-engagement nudges, admin signals).
/// Enqueued by the engine, delivered by the dispatcher job.
model Notification {
  id            String              @id @default(cuid())
  enrollmentId  String?
  enrollment    Enrollment?         @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  recipientKind RecipientKind
  recipient     String // email or identifier
  channel       NotificationChannel @default(CONSOLE)
  subject       String?
  body          String
  /// True when the body was produced by the AI provider (vs. template fallback).
  aiGenerated   Boolean             @default(false)
  /// Name of the AI / delivery provider used.
  provider      String?
  status        NotificationStatus  @default(PENDING)
  error         String?
  attempts      Int                 @default(0)
  createdAt     DateTime            @default(now())
  sentAt        DateTime?

  @@index([status])
  @@index([enrollmentId])
}
