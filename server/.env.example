# KD-HCBLM server — environment template. Copy to .env and adjust.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- AI adaptive nudges / feedback / drafting (optional; template fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-haiku-4-5-20251001

# --- embeddings for semantic search (optional; local fallback otherwise) ---
# VOYAGE_API_KEY=...
# OPENAI_API_KEY=...
# EMBEDDING_MODEL=voyage-3

# --- notification delivery (optional; defaults to console) ---
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/notify

# --- xAPI LRS forwarding (optional; no-op when unset) ---
# LRS_ENDPOINT=https://lrs.example.com/xapi
# LRS_KEY=...
# LRS_SECRET=...

# --- public base + verifiable credentials (Open Badges 2.0 / 3.0) ---
PUBLIC_BASE_URL=http://localhost:4000
CREDENTIAL_ISSUER_NAME=KOMPETENCES AFRICA
CREDENTIAL_ISSUER_URL=https://declick.kompetences.net

# --- authentication (first-party JWT / OAuth 2.1) ---
AUTH_ISSUER=https://api.declick.kompetences.net
AUTH_AUDIENCE=declick-api
ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
# ES256 keys (PEM). If unset, an ephemeral keypair is generated at boot (dev only).
# Generate with: npm run keygen
# AUTH_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# AUTH_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# During rotation, keep the OUTGOING public key here so old tokens still verify:
# AUTH_JWT_PREVIOUS_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Dev-only x-user-id auth bypass. Strict opt-in (disabled unless set to "true"),
# and refused entirely in production. Enable for local development:
AUTH_DEV_HEADER=true

# --- brute-force defences ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
RATE_LIMIT_MAX=300        # per IP per minute (global)
AUTH_RATE_LIMIT_MAX=10    # per IP per minute (auth endpoints)

# --- external IdP / enterprise SSO (OIDC, optional) ---
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
# OIDC_AUDIENCE=<client-id>
# OIDC_JIT_PROVISION=false

# --- enterprise SSO (SAML 2.0, optional) ---
# SAML_ENTRY_POINT=https://idp.example.com/app/sso/saml
# SAML_CALLBACK_URL=https://api.declick.kompetences.net/api/v1/auth/saml/acs
# SAML_ISSUER=declick-api
# SAML_IDP_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# SAML_JIT_PROVISION=false

# --- blended live sessions (Zoom / Teams, optional; manual links otherwise) ---
# MEETING_PROVIDER=manual            # zoom | teams | manual
# ZOOM_ACCOUNT_ID=...
# ZOOM_CLIENT_ID=...
# ZOOM_CLIENT_SECRET=...
# TEAMS_TENANT_ID=...
# TEAMS_CLIENT_ID=...
# TEAMS_CLIENT_SECRET=...
# TEAMS_HOST_USER_ID=...

# --- Observability (Prometheus /metrics, off by default) ---
# METRICS_ENABLED=true
# METRICS_TOKEN=change-me-long-random   # required scrape bearer token
